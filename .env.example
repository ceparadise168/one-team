# ------------------------------------------------------------
# one-team local/deployment environment template
# Copy to .env and replace placeholder values.
# ------------------------------------------------------------

# === API runtime ===
AWS_REGION=ap-northeast-1
USE_AWS_SECRETS_MANAGER=false
USE_DYNAMODB_REPOSITORIES=false
LINE_INTEGRATION_MODE=stub
LINE_API_BASE_URL=https://api.line.me
LINE_WEBHOOK_VERIFY_TOKEN_PREFIX=line-verify-
LINE_SECRET_PREFIX=one-team/dev/tenants
TENANTS_TABLE_NAME=one-team-dev-tenants
INVITATIONS_TABLE_NAME=one-team-dev-invitations
EMPLOYEES_TABLE_NAME=one-team-dev-employees
SESSIONS_TABLE_NAME=one-team-dev-sessions
TOKEN_REVOCATIONS_TABLE_NAME=one-team-dev-token-revocations
AUDIT_EVENTS_TABLE_NAME=one-team-dev-audit-events
PUBLIC_API_BASE_URL=https://api.example.com
INVITE_BASE_URL=https://app.example.com/invite
DIGITAL_ID_SIGNING_SECRET=replace-with-strong-random-secret
ACCESS_TOKEN_SECRET=replace-with-strong-random-secret
SCANNER_API_KEY=dev-scanner-key

# === CDK stage accounts ===
AWS_ACCOUNT_ID_DEV=111111111111
AWS_ACCOUNT_ID_STAGING=222222222222
AWS_ACCOUNT_ID_PROD=333333333333

# === Smoke test inputs ===
# Base URL from deployed ApiUrl output
API_URL=https://<your-api-id>.execute-api.ap-northeast-1.amazonaws.com/dev
ADMIN_TOKEN=admin-token
CHANNEL_ID=1234567890
CHANNEL_SECRET=1234567890abcdef
LOGIN_CHANNEL_ID=1234567890
LOGIN_CHANNEL_SECRET=1234567890abcdef
WEBHOOK_VERIFY_TOKEN=line-verify-1234567890
LINE_ID_TOKEN=line-id:U1001
TENANT_NAME=ACME
ADMIN_EMAIL=hr@acme.test
RECIPIENT_EMAIL=user@acme.test
EMPLOYEE_ID=E001
TTL_MINUTES=60
RUN_OFFBOARD_CHECK=true
